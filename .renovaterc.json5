{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "github>home-operations/renovate-presets#2.0.0",
    "github>Faustvii/home-ops//.renovate/autoMerge.json5",
    "github>Faustvii/home-ops//.renovate/changelogs.json5",
    "github>Faustvii/home-ops//.renovate/groups.json5",
    "github>Faustvii/home-ops//.renovate/labels.json5",
    "github>Faustvii/home-ops//.renovate/talos.json5",
    "github>Faustvii/home-ops//.renovate/managers/minecraft.json5",
  ],
  dependencyDashboard: true,
  dependencyDashboardTitle: "Renovate Dashboard 🤖",
  ignorePaths: ["**/*.sops.*"],
  suppressNotifications: [
    "prEditedNotification",
    "prIgnoreNotification",
  ],
}
