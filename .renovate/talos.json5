{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      description: "Separate Major, Minor and Patch for Talos Installer",
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
      matchDatasources: [
        "docker",
        "github-releases",
        "github-tags",
        "custom.talos-factory"
      ],
      matchPackageNames: [
        "ghcr.io/siderolabs/installer",
        "ghcr.io/siderolabs/talosctl",
        "aqua:siderolabs/talos",
        "siderolabs/talos",
        "/factory\\.talos\\.dev/"
      ],
      separateMajorMinor: true,
      separateMinorPatch: true
    }
  ],
}
