{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      description: "Override Helmfile Dependency Name",
      matchDatasources: [
        "docker"
      ],
      matchManagers: [
        "helmfile"
      ],
      overrideDepName: "{{packageName}}",
    },
    {
      description: "Override Talos Installer Package Name",
      matchDatasources: [
        "docker"
      ],
      matchPackageNames: [
        "/factory\\.talos\\.dev/"
      ],
      overridePackageName: "ghcr.io/siderolabs/installer",
    },
    {
      description: "Separate Major, Minor and Patch for Talos Installer",
      matchDatasources: [
        "docker"
      ],
      matchPackageNames: [
        "ghcr.io/siderolabs/installer"
      ],
      separateMajorMinor: true,
      separateMinorPatch: true
    },
    {
      "matchPackageNames": ["ghcr.io/pando85/helm-charts/kaniop"],
      "sourceUrl": "https://github.com/pando85/kaniop"
    },
    {
      description: "Normalize Kanidm source mapping and tag parsing",
      matchDatasources: ["docker"],
      matchPackageNames: [
        "mirror.gcr.io/kanidm/server",
        "docker.io/kanidm/server",
        "kanidm/server"
      ],
      sourceUrl: "https://github.com/kanidm/kanidm",
      extractVersion: "^v?(?<version>\\d+\\.\\d+\\.\\d+(?:[-+].+)?)$",
      versioning: "semver-coerced"
    },
    {
      "matchPackageNames": ["mirror.gcr.io/envoyproxy/envoy"],
      "sourceUrl": "https://github.com/envoyproxy/envoy"
    }
  ],
}
